    "AZ_API_ID = 10229\n",
    "AZ_FIFA_ID = 1906\n",
    "\n",
    "# Query\n",
    "query  = f\"\"\"\n",
    "\n",
    "SELECT season, COUNT(*) AS aantal_gespeelde_wedstrijden\n",
    "FROM Match\n",
    "\n",
    "WHERE home_team_api_id = {AZ_API_ID}\n",
    "   OR away_team_api_id = {AZ_API_ID}\n",
    "\n",
    "GROUP BY season\n",
    "ORDER BY season;\n",
    "\n",
    "\"\"\"\n",
    "# Opslaan data uit query in DataFrame en tonen\n",
